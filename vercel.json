{
      "version": 2,
      "installCommand": "pip install -r requirements.txt && playwright install chromium --with-deps",
      "builds": [
              {
                        "src": "app.py",
                        "use": "@vercel/python",
                        "config": {
                                    "maxLambdaSize": "50mb"
                        }
              }
      ],
      "routes": [
              {
                        "src": "/(.*)",
                        "dest": "app.py"
              }
      ]
}
